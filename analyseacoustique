<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analyse Acoustique & CCTP - Version Stable</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/react@18/umd/react.development.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @keyframes spin-slow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        .animate-spin-slow { animation: spin-slow 8s linear infinite; }
        body { background-color: #f3f4f6; font-family: ui-sans-serif, system-ui, sans-serif; }
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #e5e7eb; border-radius: 10px; }
        
        /* Fix for potential layout shifts during icon loading */
        .icon-container { display: inline-flex; align-items: center; justify-content: center; }
        
        /* Table styles */
        .result-table th { background-color: #f9fafb; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useRef } = React;

        /**
         * Composant Icon corrigé pour éviter les erreurs "removeChild" de React.
         */
        const Icon = ({ name, size = 24, className = "" }) => {
            const containerRef = useRef(null);

            useEffect(() => {
                if (window.lucide && containerRef.current) {
                    containerRef.current.innerHTML = `<i data-lucide="${name}" class="${className}" style="width: ${size}px; height: ${size}px;"></i>`;
                    window.lucide.createIcons({
                        node: containerRef.current
                    });
                }
            }, [name, size, className]);

            return <span ref={containerRef} className="icon-container leading-none"></span>;
        };

        const App = () => {
            const [activeStep, setActiveStep] = useState(1);
            const [importMode, setImportMode] = useState('upload');
            const [showTable, setShowTable] = useState(false);
            const [searchTerm, setSearchTerm] = useState('');
            const [selectedFiles, setSelectedFiles] = useState([
                { id: '1', name: 'Rapport acoustique_V1.pdf', type: 'new' }
            ]);

            const steps = [
                { id: 1, label: 'Import', sub: 'Document' },
                { id: 2, label: 'Données', sub: 'Extraction' },
                { id: 3, label: 'Avertissement', sub: 'Validation' },
                { id: 4, label: 'Résultats', sub: 'Analyse Ynor' },
                { id: 5, label: 'Livrable', sub: 'FED' },
            ];

            const projectFiles = [
                { id: 'p1', name: 'CCTP Lot 03 - Gros Oeuvre.pdf', date: '12/03/2024' },
                { id: 'p2', name: 'Notice Acoustique Phase PRO.docx', date: '10/03/2024' },
                { id: 'p3', name: 'CCTP Lot 12 - Plomberie.pdf', date: '05/03/2024' },
                { id: 'p4', name: 'CCTP - Menuiseries Extérieures.pdf', date: '01/03/2024' },
            ];

            const filteredProjectFiles = projectFiles.filter(f => 
                f.name.toLowerCase().includes(searchTerm.toLowerCase())
            );

            const toggleFileSelection = (file) => {
                if (selectedFiles.find(f => f.id === file.id)) {
                    setSelectedFiles(selectedFiles.filter(f => f.id !== file.id));
                } else {
                    setSelectedFiles([...selectedFiles, { ...file, type: 'project' }]);
                }
            };

            const renderStep1 = () => (
                <div className="p-8 animate-in fade-in duration-500">
                    <div className="text-center mb-8">
                        <h2 className="text-2xl font-bold text-purple-600 mb-2">Importez vos documents</h2>
                        <p className="text-gray-500">Téléchargez un nouveau document ou sélectionnez-en un existant</p>
                    </div>
                    <div className="bg-blue-50 border border-blue-100 rounded-xl p-4 mb-8 text-center text-sm text-blue-700">
                        Le processus prend plusieurs minutes. La fermeture de la fenêtre ne mettra pas en pause l'analyse.
                    </div>
                    <div className="flex justify-center mb-8">
                        <div className="bg-gray-100 p-1 rounded-lg flex gap-1">
                            <button onClick={() => setImportMode('upload')} className={`px-6 py-2 rounded-md flex items-center gap-2 text-sm font-semibold transition-all ${importMode === 'upload' ? 'bg-white shadow-sm text-blue-600' : 'text-gray-500'}`}>
                                <Icon name="cloud-upload" size={18} /> Nouvel import
                            </button>
                            <button onClick={() => setImportMode('library')} className={`px-6 py-2 rounded-md flex items-center gap-2 text-sm font-semibold transition-all ${importMode === 'library' ? 'bg-white shadow-sm text-blue-600' : 'text-gray-500'}`}>
                                <Icon name="library" size={18} /> Documents projet
                            </button>
                        </div>
                    </div>
                    <div className="min-h-[250px]">
                        {importMode === 'upload' ? (
                            <div className="border-2 border-dashed border-gray-200 rounded-2xl flex flex-col items-center justify-center p-12 hover:border-blue-300 cursor-pointer group transition-colors">
                                <Icon name="cloud-upload" size={48} className="text-blue-500 mb-4 group-hover:scale-110 transition-transform" />
                                <p className="text-lg font-medium text-gray-700 underline underline-offset-4 decoration-2 decoration-blue-200">Cliquer pour importer</p>
                                <p className="text-xs text-gray-400 mt-2">.pdf, .doc ou .docx</p>
                            </div>
                        ) : (
                            <div className="bg-white border rounded-2xl overflow-hidden flex flex-col h-[300px] shadow-sm">
                                <div className="p-4 bg-gray-50 border-b flex gap-4">
                                    <div className="relative flex-1">
                                        <Icon name="search" size={18} className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" />
                                        <input type="text" placeholder="Rechercher un document..." className="w-full pl-10 pr-4 py-2 border rounded-lg text-sm outline-none focus:ring-2 focus:ring-blue-100" value={searchTerm} onChange={(e) => setSearchTerm(e.target.value)} />
                                    </div>
                                </div>
                                <div className="flex-1 overflow-y-auto custom-scrollbar">
                                    {filteredProjectFiles.map(file => (
                                        <div key={file.id} onClick={() => toggleFileSelection(file)} className={`flex items-center justify-between p-4 border-b cursor-pointer transition-colors ${selectedFiles.find(f => f.id === file.id) ? 'bg-blue-50' : 'hover:bg-gray-50'}`}>
                                            <div className="flex items-center gap-3">
                                                <Icon name="file-text" className="text-blue-500" />
                                                <div className="flex flex-col">
                                                    <span className="text-sm font-medium">{file.name}</span>
                                                    <span className="text-[10px] text-gray-400">Ajouté le {file.date}</span>
                                                </div>
                                            </div>
                                            <div className={`w-6 h-6 rounded-full border-2 flex items-center justify-center transition-all ${selectedFiles.find(f => f.id === file.id) ? 'bg-blue-600 border-blue-600 text-white' : 'border-gray-200'}`}>
                                                <Icon name="check" size={14} />
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        )}
                    </div>
                </div>
            );

            const renderStep2 = () => (
                <div className="p-8 animate-in fade-in duration-500">
                    <div className="text-center mb-8">
                        <h2 className="text-2xl font-bold text-purple-600 mb-2">Données extraites</h2>
                        <p className="text-gray-500">Analysées par l'IA pour ce projet</p>
                    </div>
                    <div className="space-y-6 max-w-4xl mx-auto">
                        <div className="border rounded-xl bg-white shadow-sm overflow-hidden">
                            <div className="p-4 bg-gray-50 border-b flex justify-between items-center"><h3 className="font-bold text-gray-700 flex items-center gap-2"><Icon name="info" size={18} className="text-blue-500" /> Informations Projet</h3><Icon name="chevron-down" className="text-gray-400" /></div>
                            <div className="p-6">
                                <div className="bg-purple-50 p-5 rounded-xl border border-purple-100">
                                    <div className="flex gap-4 mb-4 items-start">
                                        <div className="bg-white p-2 rounded-lg shadow-sm text-purple-600 shrink-0"><Icon name="building-2" /></div>
                                        <div><h4 className="font-bold text-purple-900 text-sm">Type de bâtiment</h4><p className="text-xs text-gray-600 mt-1 leading-relaxed">Logement collectif R+7 sur 1 niveau de sous-sol.</p></div>
                                    </div>
                                    <div className="flex gap-2">
                                        <button className="bg-green-600 text-white text-[10px] px-3 py-1.5 rounded-lg font-bold hover:bg-green-700 flex items-center gap-1"><Icon name="plus" size={12} /> Insérer notice</button>
                                        <button className="bg-blue-600 text-white text-[10px] px-3 py-1.5 rounded-lg font-bold hover:bg-blue-700 flex items-center gap-1"><Icon name="copy" size={12} /> Copier</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            );

            const renderStep3 = () => (
                <div className="p-12 animate-in zoom-in-95 duration-500 flex flex-col items-center">
                    <h2 className="text-2xl font-bold text-purple-600 mb-8 uppercase tracking-widest">À lire attentivement</h2>
                    <div className="bg-orange-50 border border-orange-100 rounded-2xl p-10 w-full max-w-3xl shadow-md">
                        <div className="flex gap-4 mb-6 text-orange-700"><Icon name="alert-triangle" size={32} className="shrink-0" /><h3 className="text-xl font-bold">Points d'attention :</h3></div>
                        <ul className="space-y-4 text-orange-900 list-disc pl-5 mb-8">
                            <li className="text-lg leading-relaxed font-medium text-orange-800">Les éléments sur plans n'ont pas été vérifiés.</li>
                            <li className="text-lg leading-relaxed font-medium text-orange-800">Les parois issues des CCTPs sont recomposées à partir des différents lots et nécessitent une relecture de votre part.</li>
                        </ul>
                        <div className="pt-6 border-t border-orange-200"><p className="text-orange-900 font-bold italic">L'ensemble de ces points de contrôle nécessite une vérification par les responsables de mission.</p></div>
                    </div>
                </div>
            );

            const renderStep4 = () => (
                <div className="p-8 animate-in fade-in duration-500">
                    <div className="text-center mb-8">
                        <h2 className="text-2xl font-bold text-purple-600 mb-2 uppercase tracking-wide">Résultats d'analyse</h2>
                    </div>
                    <div className="bg-blue-50 border border-blue-100 rounded-xl p-5 mb-8 text-xs text-blue-800 leading-relaxed max-w-4xl mx-auto shadow-sm">
                        <p className="font-bold mb-1">Sélectionnez les thématiques à insérer dans un avis</p>
                        La sélection de thématique donnera lieu à la création d'une FED brouillon avec un seul avis. Le texte sera pré-inséré dans l'avis. Attention, la sélection de thématique n'est possible qu'une seule fois.
                    </div>

                    <div className="bg-white border rounded-2xl p-6 max-w-5xl mx-auto shadow-sm border-blue-100">
                        <div className="flex gap-5">
                            <div className="pt-1"><input type="checkbox" className="w-5 h-5 rounded border-gray-300 text-blue-600 cursor-pointer focus:ring-blue-200" defaultChecked /></div>
                            <div className="flex-1">
                                <div className="flex justify-between items-start mb-4">
                                    <h3 className="font-bold text-blue-900 text-base leading-tight">[NOTICE] Vérification d'isolement acoustique au bruit aérien (Arrêté du 30 juin 1999)</h3>
                                    <div className="bg-green-100 text-green-700 px-4 py-1.5 rounded-full text-[10px] font-extrabold whitespace-nowrap ml-4 flex items-center gap-1 shadow-sm">
                                        <Icon name="check-circle-2" size={14} /> 3/4 CONFORME
                                    </div>
                                </div>
                                
                                <div className="bg-gray-50 p-4 rounded-xl border border-gray-100 mb-4 italic text-[13px] text-gray-600 leading-relaxed">
                                    Analyse des solutions constructives pour les bruits aériens (façades, planchers bas et toitures). Les épaisseurs et matériaux identifiés ont été comparés aux référentiels Qualitel.
                                </div>

                                <button onClick={() => setShowTable(!showTable)} className="text-blue-600 text-sm font-bold flex items-center gap-1.5 hover:underline group py-2">
                                    <Icon name={showTable ? "chevron-up" : "chevron-down"} size={16} className="group-hover:translate-y-0.5 transition-transform" /> 
                                    {showTable ? "Masquer l'explication" : "Voir l'explication détaillée"}
                                </button>

                                {showTable && (
                                    <div className="mt-6 border rounded-xl overflow-hidden shadow-sm animate-in slide-in-from-top-4 duration-300">
                                        <div className="bg-gray-50 p-3 border-b border-gray-200">
                                            <h4 className="text-xs font-bold text-gray-700">6. Synthèse par paroi opaque périphérique (bruits aériens – QA 2.10 à 2.18)</h4>
                                        </div>
                                        <div className="overflow-x-auto">
                                            <table className="w-full text-left text-[11px] leading-snug border-collapse result-table">
                                                <thead className="text-gray-600 uppercase tracking-tighter font-bold border-b">
                                                    <tr>
                                                        <th className="p-3 border-r w-1/4">Paroi</th>
                                                        <th className="p-3 border-r w-1/4">Caractéristiques clés</th>
                                                        <th className="p-3 border-r w-1/4">Référence Qualitel (exemples)</th>
                                                        <th className="p-3 w-1/4">Analyse de conformité QA 2.10–2.18</th>
                                                    </tr>
                                                </thead>
                                                <tbody className="divide-y text-gray-700">
                                                    <tr>
                                                        <td className="p-3 border-r font-bold bg-white">Façades logement / extérieur</td>
                                                        <td className="p-3 border-r">Voile béton 16 cm (ms ≥ 375 kg/m²) + ITI Th‑A+ PREGYMAX, Rw+Ctr ≈ 56 dB</td>
                                                        <td className="p-3 border-r text-gray-500">Voile béton ≥ 16 cm, doublage ITI Th‑A/Th‑A+, planchers béton ≥ 20–24 cm, jonctions 2/3 mur</td>
                                                        <td className="p-3 text-green-700 font-medium bg-green-50/20">Conforme aux combinaisons Qualitel pour façades lourdes. Compatible QA 2.10–2.18 sous réserve de jonctions.</td>
                                                    </tr>
                                                    <tr className="bg-gray-50/30">
                                                        <td className="p-3 border-r font-bold bg-white">Plancher bas RDC sur garage</td>
                                                        <td className="p-3 border-r">Dalle béton 230 mm + flocage laine projetée 150 mm ΔRw+C ≥ 2 dB + chape/sous‑couche, Rw+C ≥ 65 dB</td>
                                                        <td className="p-3 border-r text-gray-500">Plancher béton ≥ 20–22 cm, isolation sous‑face par flocage/laine projetée Δ[Rw+C] ≥ 2 dB</td>
                                                        <td className="p-3 text-green-700 font-medium bg-green-50/20">Épaisseur et système conformes aux tableaux Qualitel. A priori conforme aux QA bruits aériens verticaux.</td>
                                                    </tr>
                                                    <tr>
                                                        <td className="p-3 border-r font-bold bg-white">Plancher R+1 / locaux non chauffés</td>
                                                        <td className="p-3 border-r">Dalle béton 200 mm + isolant sous‑face ΔRw+C ≥ 2 dB, Rw+C ≥ 62 dB</td>
                                                        <td className="p-3 border-r text-gray-500">Plancher béton ≥ 20 cm, isolant sous‑face Δ[Rw+C] ≥ 2 dB</td>
                                                        <td className="p-3 text-green-700 font-medium bg-green-50/20">Configuration alignée avec les solutions Qualitel. A priori conforme aux QA 2.10–2.16.</td>
                                                    </tr>
                                                    <tr className="bg-orange-50/10">
                                                        <td className="p-3 border-r font-bold bg-white">Toitures terrasses (acc./inacc.)</td>
                                                        <td className="p-3 border-r">Dalle béton 200 mm, Rw+Ctr ≥ 57 dB (dalle seule), Δ(Rw+Ctr) ≥ –7 dB avec complexe</td>
                                                        <td className="p-3 border-r text-gray-500">Toitures lourdes en béton, valeurs forfaitaires Rw+Ctr cohérentes avec planchers lourds</td>
                                                        <td className="p-3 text-orange-700 font-medium bg-orange-50/20 underline decoration-orange-300 underline-offset-2">Pas de point bloquant paroi seule. Conformité DnT,A dépend des calculs transmissions latérales.</td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                )}
                            </div>
                        </div>
                    </div>
                </div>
            );

            const renderStep5 = () => (
                <div className="p-8 animate-in slide-in-from-right-10 duration-500 h-full flex flex-col">
                    <div className="flex gap-6 h-[500px] max-w-5xl mx-auto w-full">
                        <div className="flex-1 bg-blue-50/30 border border-blue-100 rounded-2xl p-4 flex flex-col shadow-inner">
                            <div className="flex justify-between items-center mb-5 px-2">
                                <span className="text-[11px] font-bold bg-blue-200 text-blue-700 px-3 py-1.5 rounded-full flex items-center gap-2 shadow-sm">
                                    <div className="w-1.5 h-1.5 bg-blue-600 rounded-full animate-pulse"></div> En cours
                                </span>
                                <span className="font-extrabold text-blue-700 text-sm">9</span>
                            </div>
                            <div className="flex-1 overflow-y-auto space-y-2.5 pr-1 custom-scrollbar">
                                {["[CCTP] Aires absorption", "[CCTP-v2] Bruits de chocs", "[CCTP] Composition façades", "[NOTICE] Composition bruits", "[CCTP-v1] Bruits de choc", "[CCTP] Bruits aériens intérieurs", "[NOTICE] Aires absorption", "[NOTICE] Bruits aériens", "[NOTICE] Equipement"].map((item, i) => (
                                    <div key={i} className="bg-white p-4 rounded-xl shadow-sm text-[11px] font-semibold text-gray-700 border border-transparent hover:border-blue-300 cursor-pointer flex gap-3 group transition-all hover:shadow-md">
                                        <Icon name="file-text" size={14} className="text-gray-300 group-hover:text-blue-500" />
                                        <span>{item}</span>
                                    </div>
                                ))}
                                <div className="border-2 border-dashed border-blue-200 rounded-xl p-4 text-center text-[11px] text-blue-500 font-bold cursor-pointer hover:bg-blue-100/50 transition-colors flex items-center justify-center gap-2">
                                    <Icon name="plus" size={14} /> Nouvelle page
                                </div>
                            </div>
                        </div>
                        <div className="flex-1 bg-green-50/30 border border-green-100 rounded-2xl p-4 flex flex-col shadow-inner">
                            <div className="flex justify-between items-center mb-5 px-2">
                                <span className="text-[11px] font-bold bg-green-200 text-green-700 px-3 py-1.5 rounded-full flex items-center gap-2 shadow-sm">
                                    <div className="w-1.5 h-1.5 bg-green-600 rounded-full"></div> Terminé
                                </span>
                                <span className="font-extrabold text-green-700 text-sm">4</span>
                            </div>
                            <div className="flex-1 overflow-y-auto space-y-2.5 pr-1 custom-scrollbar">
                                {["[NOTICE] Bruit de choc L'nT,w", "[NOTICE] Equipements LnAT", "[NOTICE] Bruit aérien 1999", "[NOTICE/CCTP] Qualitel"].map((item, i) => (
                                    <div key={i} className="bg-white p-4 rounded-xl shadow-sm text-[11px] font-semibold text-gray-700 border border-transparent hover:border-green-400 cursor-pointer flex gap-3 group transition-all hover:shadow-md">
                                        <Icon name="file-text" size={14} className="text-green-500" />
                                        <span>{item}</span>
                                    </div>
                                ))}
                            </div>
                        </div>
                    </div>
                </div>
            );

            return (
                <div className="min-h-screen flex items-center justify-center p-4">
                    <div className="bg-white w-full max-w-6xl rounded-2xl shadow-2xl overflow-hidden flex flex-col min-h-[92vh] border border-gray-100">
                        
                        <div className="p-6 border-b flex justify-between items-center sticky top-0 bg-white z-50">
                            <div className="flex items-center gap-4">
                                <div className="bg-purple-100 p-2.5 rounded-full text-purple-600 animate-spin-slow shadow-sm border border-purple-200">
                                    <Icon name="refresh-cw" size={24} />
                                </div>
                                <div>
                                    <h1 className="text-lg font-extrabold text-purple-900 tracking-tight">Analyse Acoustique & CCTP</h1>
                                    <p className="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Extraction intelligente des données</p>
                                </div>
                            </div>
                            <button className="p-2 text-gray-300 hover:text-gray-600 hover:bg-gray-100 rounded-full transition-all">
                                <Icon name="x" size={24} />
                            </button>
                        </div>

                        <div className="px-16 py-8 border-b bg-gray-50/40">
                            <div className="relative flex justify-between items-center max-w-4xl mx-auto">
                                <div className="absolute top-5 left-0 w-full h-0.5 bg-gray-200 -z-0"></div>
                                {steps.map(s => (
                                    <div key={s.id} className="relative z-10 flex flex-col items-center">
                                        <div className={`w-10 h-10 rounded-full flex items-center justify-center border-2 transition-all duration-300 shadow-sm
                                            ${activeStep >= s.id ? 'bg-blue-600 border-blue-600 text-white' : 'bg-white border-gray-300 text-gray-300'}`}>
                                            {activeStep > s.id ? <Icon name="check" size={20} /> : s.id}
                                        </div>
                                        <span className={`text-[10px] mt-2.5 font-bold uppercase tracking-tighter ${activeStep === s.id ? 'text-blue-600' : 'text-gray-400'}`}>{s.label}</span>
                                    </div>
                                ))}
                            </div>
                        </div>

                        <div className="flex-1 overflow-y-auto custom-scrollbar bg-white">
                            {activeStep === 1 && renderStep1()}
                            {activeStep === 2 && renderStep2()}
                            {activeStep === 3 && renderStep3()}
                            {activeStep === 4 && renderStep4()}
                            {activeStep === 5 && renderStep5()}
                        </div>

                        <div className="p-6 border-t bg-gray-50/90 backdrop-blur-sm flex justify-between items-center shrink-0">
                            <div>
                                {activeStep > 1 && (
                                    <button onClick={() => setActiveStep(activeStep - 1)} className="px-6 py-2.5 rounded-xl text-sm font-bold flex items-center gap-2 bg-white border border-gray-200 text-gray-600 hover:bg-gray-50 hover:border-blue-400 transition-all shadow-sm">
                                        <Icon name="chevron-left" size={18} /> Précédent
                                    </button>
                                )}
                            </div>
                            <div className="flex gap-4 items-center">
                                <button onClick={() => {setSelectedFiles([]); setActiveStep(1)}} className="px-4 py-2 text-[10px] font-black text-red-400 hover:text-red-600 transition-colors uppercase tracking-widest">Réinitialiser</button>
                                <button className="px-6 py-2.5 bg-white border border-blue-200 text-blue-600 font-bold rounded-xl text-sm shadow-sm flex items-center gap-2 hover:bg-blue-50 transition-all"><Icon name="eye" size={18} /> Voir document</button>
                                <button onClick={() => setActiveStep(Math.min(5, activeStep + 1))} className="px-8 py-2.5 bg-blue-600 text-white rounded-xl font-extrabold shadow-lg shadow-blue-100 hover:bg-blue-700 hover:-translate-y-0.5 active:translate-y-0 transition-all flex items-center gap-2">
                                    {activeStep === 1 ? "Lancer l'analyse" : activeStep === 3 ? "J'ai compris, suivant" : activeStep === 5 ? "Finaliser" : "Suivant"} 
                                    <Icon name="chevron-right" size={18} />
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
